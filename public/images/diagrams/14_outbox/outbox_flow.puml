@startuml outbox_flow
!include ../theme.iuml

title Transactional Outbox: 4 fáze publikování doménového eventu

participant "PlaceOrderHandler" as h
database "DB\n(orders + outbox)" as db
participant "Outbox Relay\n(messenger:consume)" as relay
queue "RabbitMQ" as mq
participant "Subscriber BC" as sub

== Fáze 1: business transakce ==
h -> db : BEGIN
h -> db : INSERT INTO orders (...)
h -> db : INSERT INTO outbox\n(event_id, payload, status='pending')
h -> db : COMMIT
note right of db
  Atomicky: order i outbox row.
  Nelze ztratit jeden bez druhého.
end note

== Fáze 2: relay polluje outbox ==
relay -> db : SELECT * FROM outbox\nWHERE status='pending'\nORDER BY occurred_at LIMIT 100
db -> relay : 100 rows

== Fáze 3: publish do brokera ==
loop pro každý row
  relay -> mq : publish(event_id, payload)
  mq --> relay : ack
  relay -> db : UPDATE outbox SET status='sent',\nsent_at=NOW() WHERE id=...
end

== Fáze 4: subscriber konzumuje ==
mq -> sub : delivery
sub -> sub : process (idempotent inbox check)
sub --> mq : ack

@enduml
