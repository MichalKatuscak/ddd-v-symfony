@startuml hexagonal_vs_onion
!include ../theme.iuml

title Čtyři architektonické styly aplikované na DDD

' ============================================================
' 1. Layered (klasická vrstvená)
' ============================================================
package "1. Layered (klasická)" as P_LAYERED {
    rectangle "Presentation\n(Controller)" as l_pres
    rectangle "Application\n(Service)" as l_app
    rectangle "Domain\n(Entity)" as l_dom $ACCENT
    rectangle "Infrastructure\n(Doctrine, HTTP)" as l_inf

    l_pres -down-> l_app
    l_app  -down-> l_dom
    l_dom  -down-> l_inf

    note right of l_inf
      Doménové třídy
      závisí na Doctrine.
      Vrstva je <i>pod</i> nimi,
      ale stále ji <b>používají</b>.
    end note
}

' ============================================================
' 2. Hexagonal (Ports & Adapters, Cockburn 2005)
' ============================================================
package "2. Hexagonal (Cockburn 2005)" as P_HEX {
    rectangle "HTTP Adapter\n(Symfony Controller)" as h_http
    rectangle "Inbound Port\n<<interface>>" as h_in
    rectangle "Domain Core\n(Aggregate, VO)" as h_core $ACCENT
    rectangle "Outbound Port\n<<interface>>" as h_out
    rectangle "Doctrine Adapter\n(Repository impl.)" as h_doc

    h_http -right-> h_in
    h_in   -right-> h_core
    h_core -right-> h_out
    h_out  -right-> h_doc

    note bottom of h_core
      Doména závisí <b>jen</b>
      na portech (interfaces).
      Adaptéry jsou <i>plug-in</i>.
    end note
}

' ============================================================
' 3. Onion (Palermo 2008)
' ============================================================
package "3. Onion (Palermo 2008)" as P_ONION {
    rectangle "UI / Infrastructure" as o_ui
    rectangle "Application Services" as o_as
    rectangle "Domain Services" as o_ds
    rectangle "Domain Model\n(Entity, VO)" as o_dom $ACCENT

    o_ui -down-> o_as
    o_as -down-> o_ds
    o_ds -down-> o_dom

    note right of o_dom
      Závislosti směřují
      vždy <b>dovnitř</b>.
      Doména nezná infra.
    end note
}

' ============================================================
' 4. Clean (Robert C. Martin 2012)
' ============================================================
package "4. Clean (Martin 2012)" as P_CLEAN {
    rectangle "Frameworks &\nDrivers" as c_fd
    rectangle "Interface\nAdapters" as c_ia
    rectangle "Use Cases" as c_uc
    rectangle "Entities" as c_ent $ACCENT

    c_fd -right-> c_ia
    c_ia -right-> c_uc
    c_uc -right-> c_ent

    note bottom of c_ent
      4 koncentrické vrstvy.
      <b>Dependency Rule:</b>
      jednosměrná, dovnitř.
    end note
}

' Vizuální oddělení sloupců
P_LAYERED -[hidden]right- P_HEX
P_HEX     -[hidden]right- P_ONION
P_ONION   -[hidden]right- P_CLEAN

@enduml
