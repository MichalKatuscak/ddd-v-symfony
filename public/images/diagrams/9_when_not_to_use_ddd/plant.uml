@startuml diagram
!include ../theme.iuml

title Rozhodovací strom: Mám použít DDD?

start
:Nový projekt / architektonické rozhodnutí;

if (Komplexní doménová logika?\n(ne jen CRUD)) then (ne)
  #1B202A:DDD nepotřebuješ\n-> EasyAdmin / Flat MVC;
  stop
else (ano)
endif

if (Projekt bude žít > 1 rok?) then (ne)
  #1B202A:DDD se nevyplatí\n-> Symfony Controller + Doctrine;
  stop
else (ano)
endif

if (Přístup k doménovým\nexpertům?) then (ne)
  #1B202A:DDD bez expertů = hádání\n-> Vrstvená architektura;
  stop
else (ano)
endif

if (Tým zná DDD\nnebo má čas se učit?) then (ne)
  #1B202A:Pseudo-DDD je horší\nnež žádné DDD\n-> Architektura, kterou tým zná;
  stop
else (ano)
endif

if (Doména je stabilní?\n(ne pivot každý sprint)) then (ne)
  #1B202A:Počkej na stabilizaci\n-> Flat MVC, DDD později;
  stop
else (ano)
endif

#F0A456:DDD dává smysl\n-> Strategický i taktický design;
stop

@enduml
