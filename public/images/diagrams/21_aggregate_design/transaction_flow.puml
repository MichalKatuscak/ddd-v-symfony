@startuml transaction_flow
!include ../theme.iuml

title Tok transakce: jeden agregát na transakci + sága přes events

actor "Klient" as user
participant "Application\n(Command Handler)" as app
database "DB" as db
queue "Outbox\n+ Messenger" as bus
participant "Sága\n(Process Manager)" as saga

== Transakce 1: změna v agregátu A ==
user -> app : PlaceOrder(items)
app -> db : begin
app -> db : SELECT order WHERE id=? FOR UPDATE\n(optimistic lock)
app -> db : INSERT order, items
app -> db : INSERT outbox(OrderPlaced)
app -> db : commit
app --> user : 202 Accepted (orderId)

== Asynchronně: relay outboxu ==
db -> bus : OrderPlaced

== Transakce 2: reakce v agregátu B (oddělená) ==
bus -> saga : OrderPlaced
saga -> db : begin
saga -> db : UPDATE inventory SET reserved=...\n(jiný agregát, jiná transakce)
saga -> db : INSERT outbox(InventoryReserved)
saga -> db : commit

note over app, saga
  Žádná transakce nepřesahuje
  hranici agregátu. Ságy řeší
  konzistenci mezi agregáty.
end note

@enduml
