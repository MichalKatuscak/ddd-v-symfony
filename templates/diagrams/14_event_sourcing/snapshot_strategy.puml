@startuml snapshot_strategy
!include ../theme.iuml

title Snapshotting: zhuštěný stav místo plného replay

participant "Repository" as repo
database "Snapshot Store" as ss
database "Event Store" as es
participant "Aggregate" as agg

== Hydration s plným replay (pomalé) ==
note over repo, agg
  Long-lived agregát s 10 000 eventy:
  bez snapshotu trvá hydration sekundy.
end note

repo -> es : SELECT * FROM events\nWHERE aggregate_id = $id (10 000 řádků)
es --> repo : všechny eventy
loop 10 000×
  repo -> agg : apply(event)
end

== Hydration se snapshotem (rychlé) ==
repo -> ss : SELECT * FROM snapshots\nWHERE aggregate_id = $id\nORDER BY version DESC LIMIT 1
ss --> repo : snapshot @ version 9 800
repo -> agg : restore(snapshot.state)

repo -> es : SELECT * FROM events\nWHERE aggregate_id = $id\nAND version > 9 800
es --> repo : 200 eventů (od snapshotu)

loop 200×
  repo -> agg : apply(event)
end

repo --> agg : current state

== Periodic snapshot creation ==
note over repo, ss
  Po každých N eventech (typicky 100):
  zachycení agregátního stavu jako snapshot.
end note

repo -> agg : extractSnapshot()
agg --> repo : SnapshotData(version, state)
repo -> ss : INSERT INTO snapshots\n(aggregate_id, version, state)

@enduml
