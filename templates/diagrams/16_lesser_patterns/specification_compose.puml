@startuml
!include ../theme.iuml

title Specification Pattern: kompozice booleovské logiky

interface "Specification<T>" as spec {
  +isSatisfiedBy(T): bool
  +and(Specification<T>): Specification<T>
  +or(Specification<T>): Specification<T>
  +not(): Specification<T>
}

abstract class "CompositeSpecification<T>" as composite {
  +and(Specification<T>): Specification<T>
  +or(Specification<T>): Specification<T>
  +not(): Specification<T>
  {abstract} +isSatisfiedBy(T): bool
}

class "AndSpecification<T>" as andSpec {
  -left: Specification<T>
  -right: Specification<T>
  +isSatisfiedBy(T): bool
}

class "OrSpecification<T>" as orSpec {
  -left: Specification<T>
  -right: Specification<T>
  +isSatisfiedBy(T): bool
}

class "NotSpecification<T>" as notSpec {
  -inner: Specification<T>
  +isSatisfiedBy(T): bool
}

class "EligibleForFreeShipping" as ps {
  -threshold: Money
  +isSatisfiedBy(Order): bool
}

class "InEUCountry" as ineu {
  -country: Country
  +isSatisfiedBy(Order): bool
}

class "NotInBlacklist" as nib {
  -customerId: CustomerId
  +isSatisfiedBy(Order): bool
}

spec <|.. composite
composite <|-- andSpec
composite <|-- orSpec
composite <|-- notSpec
composite <|-- ps
composite <|-- ineu
composite <|-- nib

andSpec o-- spec : left/right
orSpec o-- spec : left/right
notSpec o-- spec : inner

note right of ps
  Konkrétní doménové
  specifikace vyjadřují
  business pravidla
  jako prvotřídní objekty.
end note

note bottom of andSpec
  Kompozice and/or/not
  → libovolné booleovské
  výrazy bez if-else stromů.
  Otevřeno pro rozšíření,
  zavřeno pro modifikaci.
end note

note left of composite
  Abstraktní třída
  poskytuje implicitní
  kombinátory pro všechny
  potomky (DRY princip).
end note

@enduml
