<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}Podrobný průvodce Domain-Driven Design v Symfony 8. Naučte se implementovat DDD architekturu ve svých Symfony projektech.{% endblock %}">
    <meta name="keywords" content="{% block meta_keywords %}Domain-Driven Design, DDD, Symfony, PHP, architektura, vývoj, CQRS, Event Sourcing{% endblock %}">
    <meta name="author" content="Michal Katuščák">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#0B0D10">
    <meta name="generator" content="Symfony 8">

    <link rel="canonical" href="{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}" />
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">

    {# Preload nejvyužívanějších písemných subsetů — Czech text potřebuje Latin + Latin Ext;
       inline code potřebuje JetBrains Mono Latin. Ostatní subsets se loadují lazily. #}
    {{ vite_font_preloads([
        'assets/fonts/inter-latin.woff2',
        'assets/fonts/inter-latin-ext.woff2',
        'assets/fonts/jetbrains-mono-latin.woff2',
    ]) }}

    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:url" content="{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}">
    <meta property="og:title" content="{% block og_title %}{{ title ?? 'Architektura DDD v Symfony 8' }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:image" content="{{ app.request.schemeAndHttpHost }}{{ asset('images/social.png') }}">
    <meta property="og:locale" content="cs_CZ">
    {%- set _pub %}{% block article_published_time %}{% endblock %}{% endset -%}
    {%- set _mod %}{% block article_modified_time %}{% endblock %}{% endset -%}
    {%- set _pub = _pub|trim -%}
    {%- set _mod = _mod|trim -%}
    {% if _pub %}<meta property="article:published_time" content="{{ _pub }}">{% endif %}
    {% if _mod %}<meta property="article:modified_time" content="{{ _mod }}">{% endif %}
    {% if _pub or _mod %}<meta property="article:author" content="Michal Katuščák">{% endif %}

    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}">
    <meta property="twitter:title" content="{% block twitter_title %}{{ block('og_title') }}{% endblock %}">
    <meta property="twitter:description" content="{% block twitter_description %}{{ block('og_description') }}{% endblock %}">
    <meta property="twitter:image" content="{{ app.request.schemeAndHttpHost }}{{ asset('images/social.png') }}">

    <title>{% block title %}{{ title ?? 'Architektura DDD v Symfony 8' }} | DDD Symfony{% endblock %}</title>

    {% block stylesheets %}
        {{ vite_entry_link_tags('app') }}
    {% endblock %}
</head>
<body>
    {%- set _route = app.request.attributes.get('_route') -%}
    {%- set _basics_routes = ['hub_basics', 'what_is_ddd', 'subdomains', 'context_mapping', 'event_storming', 'team_topologies'] -%}
    {%- set _tactics_routes = ['hub_tactics', 'basic_concepts', 'aggregate_design', 'lesser_known_patterns'] -%}
    {%- set _architecture_routes = ['hub_architecture', 'architectural_styles', 'implementation_in_symfony', 'authorization_in_ddd'] -%}
    {%- set _patterns_routes = ['hub_patterns', 'cqrs', 'event_sourcing', 'sagas', 'outbox_pattern', 'performance_aspects'] -%}
    {%- set _practice_routes = ['hub_practice', 'testing_ddd', 'migration_from_crud', 'microservices_and_ddd', 'ddd_pain_points', 'anti_patterns', 'when_not_to_use_ddd'] -%}
    {%- set _synthesis_routes = ['hub_synthesis', 'practical_examples', 'case_study'] -%}
    {%- set _reference_routes = ['hub_reference', 'ddd_ai', 'glossary', 'resources', 'cheat_sheet'] -%}

    <a href="#content" class="skip-link">Přejít na obsah</a>

    <header>
        <nav class="topnav" aria-label="Hlavní navigace">
            <div class="topnav-left">
                <a class="brand" href="{{ path('homepage') }}">
                    <svg width="28" height="28" viewBox="0 0 28 28" class="brand-mark" aria-hidden="true">
                        <rect x="1.5" y="1.5" width="25" height="25" fill="none"
                              stroke="var(--accent)" stroke-width="1"/>
                        <rect x="6"   y="6"   width="16" height="16" fill="none"
                              stroke="var(--fg-dim)" stroke-width="0.75"/>
                        <rect x="10.5" y="10.5" width="7" height="7" fill="var(--accent)"/>
                    </svg>
                    <div class="brand-text">
                        <div class="brand-title">DDD<span class="brand-dot">·</span>Symfony 8</div>
                        <div class="brand-sub">Domain-Driven Design pro pokročilé</div>
                    </div>
                </a>
            </div>
            <div class="topnav-center">
                <a class="navlink {% if _route in _basics_routes %}active{% endif %}" href="{{ path('hub_basics') }}"{% if _route == 'hub_basics' %} aria-current="page"{% elseif _route in _basics_routes %} aria-current="true"{% endif %}>Úvod</a>
                <a class="navlink {% if _route in _tactics_routes %}active{% endif %}" href="{{ path('hub_tactics') }}"{% if _route == 'hub_tactics' %} aria-current="page"{% elseif _route in _tactics_routes %} aria-current="true"{% endif %}>Taktika</a>
                <a class="navlink {% if _route in _architecture_routes %}active{% endif %}" href="{{ path('hub_architecture') }}"{% if _route == 'hub_architecture' %} aria-current="page"{% elseif _route in _architecture_routes %} aria-current="true"{% endif %}>Architektura</a>
                <a class="navlink {% if _route in _patterns_routes %}active{% endif %}" href="{{ path('hub_patterns') }}"{% if _route == 'hub_patterns' %} aria-current="page"{% elseif _route in _patterns_routes %} aria-current="true"{% endif %}>Vzory</a>
                <a class="navlink {% if _route in _practice_routes %}active{% endif %}" href="{{ path('hub_practice') }}"{% if _route == 'hub_practice' %} aria-current="page"{% elseif _route in _practice_routes %} aria-current="true"{% endif %}>Praxe</a>
                <a class="navlink {% if _route in _synthesis_routes %}active{% endif %}" href="{{ path('hub_synthesis') }}"{% if _route == 'hub_synthesis' %} aria-current="page"{% elseif _route in _synthesis_routes %} aria-current="true"{% endif %}>Syntéza</a>
                <a class="navlink {% if _route in _reference_routes %}active{% endif %}" href="{{ path('hub_reference') }}"{% if _route == 'hub_reference' %} aria-current="page"{% elseif _route in _reference_routes %} aria-current="true"{% endif %}>Reference</a>
            </div>
            <div class="topnav-right">
                <button class="nav-search" type="button" data-search-open aria-label="Hledat v knize" aria-keyshortcuts="Control+K">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <circle cx="11" cy="11" r="6"/>
                        <line x1="20" y1="20" x2="15.5" y2="15.5"/>
                    </svg>
                    <span class="nav-search-label">Hledat</span>
                    <kbd class="nav-search-kbd" aria-hidden="true">⌘K</kbd>
                </button>
                <button class="nav-toggle" aria-label="Otevřít navigaci" aria-expanded="false">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <line x1="4" y1="7" x2="20" y2="7"/>
                        <line x1="4" y1="12" x2="20" y2="12"/>
                        <line x1="4" y1="17" x2="20" y2="17"/>
                    </svg>
                </button>
            </div>
        </nav>
    </header>

    {# Tenký indikátor postupu čtení — vyplňuje ho reading-progress.js jen na kapitolách. #}
    <div class="reading-bar" data-reading-bar aria-hidden="true"></div>

    <div class="nav-drawer-backdrop" aria-hidden="true"></div>
    <aside class="nav-drawer" aria-label="Mobilní navigace">
        <ul class="nav-drawer-list">
            <li><a class="{% if _route in _basics_routes %}active{% endif %}" href="{{ path('hub_basics') }}"{% if _route == 'hub_basics' %} aria-current="page"{% elseif _route in _basics_routes %} aria-current="true"{% endif %}>Úvod a strategie</a></li>
            <li><a class="{% if _route in _tactics_routes %}active{% endif %}" href="{{ path('hub_tactics') }}"{% if _route == 'hub_tactics' %} aria-current="page"{% elseif _route in _tactics_routes %} aria-current="true"{% endif %}>Taktika</a></li>
            <li><a class="{% if _route in _architecture_routes %}active{% endif %}" href="{{ path('hub_architecture') }}"{% if _route == 'hub_architecture' %} aria-current="page"{% elseif _route in _architecture_routes %} aria-current="true"{% endif %}>Architektura</a></li>
            <li><a class="{% if _route in _patterns_routes %}active{% endif %}" href="{{ path('hub_patterns') }}"{% if _route == 'hub_patterns' %} aria-current="page"{% elseif _route in _patterns_routes %} aria-current="true"{% endif %}>Vzory</a></li>
            <li><a class="{% if _route in _practice_routes %}active{% endif %}" href="{{ path('hub_practice') }}"{% if _route == 'hub_practice' %} aria-current="page"{% elseif _route in _practice_routes %} aria-current="true"{% endif %}>Praxe</a></li>
            <li><a class="{% if _route in _synthesis_routes %}active{% endif %}" href="{{ path('hub_synthesis') }}"{% if _route == 'hub_synthesis' %} aria-current="page"{% elseif _route in _synthesis_routes %} aria-current="true"{% endif %}>Syntéza</a></li>
            <li><a class="{% if _route in _reference_routes %}active{% endif %}" href="{{ path('hub_reference') }}"{% if _route == 'hub_reference' %} aria-current="page"{% elseif _route in _reference_routes %} aria-current="true"{% endif %}>Reference</a></li>
            <li><a href="{{ path('about') }}"{% if _route == 'about' %} aria-current="page"{% endif %}>O autorovi</a></li>
        </ul>
    </aside>

    <div class="search-overlay" data-search-overlay data-open="false">
        <div class="search-backdrop" data-search-backdrop aria-hidden="true"></div>
        <div class="search-panel" role="dialog" aria-modal="true" aria-label="Hledat v knize">
            <div class="search-field">
                <svg class="search-field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <circle cx="11" cy="11" r="6"/>
                    <line x1="20" y1="20" x2="15.5" y2="15.5"/>
                </svg>
                <input
                    type="search"
                    class="search-input"
                    data-search-input
                    placeholder="Hledat kapitolu, sekci nebo pojem…"
                    aria-label="Hledat v knize"
                    role="combobox"
                    aria-expanded="true"
                    aria-controls="search-results"
                    aria-autocomplete="list"
                    autocomplete="off"
                    spellcheck="false">
                <kbd class="search-esc" aria-hidden="true">Esc</kbd>
            </div>
            <div class="search-results" id="search-results" data-search-results role="listbox" aria-label="Výsledky hledání"></div>
            <p class="search-empty" data-search-empty></p>
        </div>
    </div>

    <main id="content" tabindex="-1">
        {% block body %}{% endblock %}
    </main>

    {%- set _foot_basics       = ddd_chapters_by_group('basics') -%}
    {%- set _foot_tactics      = ddd_chapters_by_group('tactics') -%}
    {%- set _foot_architecture = ddd_chapters_by_group('architecture') -%}
    {%- set _foot_patterns     = ddd_chapters_by_group('patterns') -%}
    {%- set _foot_practice     = ddd_chapters_by_group('practice') -%}
    {%- set _foot_synthesis    = ddd_chapters_by_group('synthesis') -%}
    {%- set _foot_extras       = ddd_extras() -%}
    {%- set _foot_total        = ddd_chapters()|length -%}
    <footer class="foot-a" aria-label="Patička webu">
        <div class="foot-a-inner">
            <div class="foot-a-head">
                <div>
                    <div class="foot-a-imprint">TIRÁŽ</div>
                    <h2 class="foot-a-h">
                        Domain-Driven Design<br>
                        <em>v Symfony 8.</em>
                    </h2>
                    <div class="foot-a-sub">{{ _foot_total }} kapitol · průvodce pro seniorní vývojáře a architekty</div>
                </div>
                <dl class="foot-a-spec">
                    <div><dt>Vydáno</dt><dd>duben 2025</dd></div>
                    <div><dt>Aktualizováno</dt><dd>květen 2026</dd></div>
                    <div><dt>Stack</dt><dd>PHP 8.4 · Symfony 8</dd></div>
                    <div><dt>Sazba</dt><dd>Inter · JetBrains Mono</dd></div>
                    <div><dt>Licence</dt><dd>obsah CC BY-NC 4.0 · ukázky kódu MIT</dd></div>
                    <div><dt>Autor</dt><dd><a href="{{ path('about') }}">Michal Katuščák</a> · <a href="https://www.katuscak.cz/" rel="author">katuscak.cz ↗</a></dd></div>
                </dl>
            </div>

            <div class="foot-a-cols">
                <div class="foot-a-col">
                    <h3><a href="{{ path('hub_basics') }}">Úvod a strategie</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_basics %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                    <h3 style="margin-top:1.5rem"><a href="{{ path('hub_tactics') }}">Taktika</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_tactics %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="foot-a-col">
                    <h3><a href="{{ path('hub_architecture') }}">Architektura</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_architecture %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                    <h3 style="margin-top:1.5rem"><a href="{{ path('hub_patterns') }}">Vzory</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_patterns %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="foot-a-col">
                    <h3><a href="{{ path('hub_practice') }}">Praxe</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_practice %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                    <h3 style="margin-top:1.5rem"><a href="{{ path('hub_synthesis') }}">Syntéza</a></h3>
                    <ul class="foot-a-list">
                        {% for c in _foot_synthesis %}
                            <li><a href="{{ path(c.route) }}"><span class="foot-a-num">{{ c.n }}</span><span>{{ c.t }}</span></a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="foot-a-col">
                    <h3><a href="{{ path('hub_reference') }}">Reference</a></h3>
                    <ul class="foot-a-list">
                        {% for e in _foot_extras %}
                            <li><a href="{{ path(e.route) }}"><span class="foot-a-num">–</span><span>{{ e.t }}</span></a></li>
                        {% endfor %}
                        <li><a href="{{ path('about') }}"><span class="foot-a-num">–</span><span>O autorovi</span></a></li>
                    </ul>
                </div>
            </div>

            <div class="foot-a-base">
                <div class="foot-a-mark">
                    <span class="foot-a-mark-glyph" aria-hidden="true"></span>
                    <span>DDD · Symfony 8</span>
                </div>
                <div class="foot-a-rights">
                    <span>© {{ "now"|date("Y") }} Michal Katuščák</span>
                    <a href="{{ path('security_policy') }}">Bezpečnost</a>
                </div>
            </div>
        </div>
    </footer>

    {% block javascripts %}
        {{ vite_entry_script_tags('app') }}
    {% endblock %}

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Architektura DDD v Symfony 8",
        "url": "{{ app.request.schemeAndHttpHost }}",
        "description": "Podrobný průvodce Domain-Driven Design v Symfony 8",
        "author": {
            "@type": "Person",
            "name": "Michal Katuščák",
            "url": "https://www.katuscak.cz/",
            "sameAs": [
                "https://blog.katuscak.cz/",
                "https://www.linkedin.com/in/michal-katu%C5%A1%C4%8D%C3%A1k-04a249184/"
            ]
        },
        "publisher": {
            "@type": "Person",
            "name": "Michal Katuščák",
            "url": "https://www.katuscak.cz/",
            "sameAs": [
                "https://blog.katuscak.cz/",
                "https://www.linkedin.com/in/michal-katu%C5%A1%C4%8D%C3%A1k-04a249184/"
            ]
        },
        "inLanguage": "cs-CZ"
    }
    </script>

    {%- set _breadcrumb %}{% block breadcrumb_name %}{% endblock %}{% endset -%}
    {%- set _breadcrumb = _breadcrumb|trim -%}
    {% if _breadcrumb %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Úvod", "item": "{{ url('homepage') }}" },
            { "@type": "ListItem", "position": 2, "name": "{{ _breadcrumb }}", "item": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}" }
        ]
    }
    </script>
    {% endif %}

    {% block structured_data %}{% endblock %}
</body>
</html>
