{% extends 'base.html.twig' %}

{% block title %}DDD v Symfony 8 — Doménově řízený návrh, přeložený do Symfony{% endblock %}
{% block meta_description %}Šestnáctikapitolová příručka pro seniorní vývojáře a architekty. Od ohraničených kontextů přes CQRS a Event Sourcing až po reálné případové studie — v PHP 8.4+ a Symfony 8.{% endblock %}

{% set chapters = [
    { n: '01', route: 'what_is_ddd',              t: 'Co je Domain-Driven Design',      d: 'Filozofie, Ubiquitous Language, Bounded Context',           time: 12, lvl: 1, tag: 'Základy' },
    { n: '02', route: 'basic_concepts',           t: 'Základní koncepty DDD',           d: 'Entity · Value Objects · Agregáty · Repozitáře · Events',   time: 22, lvl: 2, tag: 'Základy' },
    { n: '03', route: 'horizontal_vs_vertical',   t: 'Vertikální slice architektura',   d: 'Slicing podle feature, ne podle vrstvy',                     time: 14, lvl: 2, tag: 'Základy' },
    { n: '04', route: 'implementation_in_symfony',t: 'Implementace v Symfony 8',        d: 'Struktura projektu, Messenger, DI, Doctrine',                time: 26, lvl: 3, tag: 'Základy' },
    { n: '05', route: 'cqrs',                     t: 'CQRS',                            d: 'Oddělení čtení a zápisu přes Messenger komponentu',          time: 20, lvl: 3, tag: 'Vzory' },
    { n: '06', route: 'event_sourcing',           t: 'Event Sourcing',                  d: 'Stav aplikace jako sekvence doménových událostí',            time: 28, lvl: 4, tag: 'Vzory' },
    { n: '07', route: 'sagas',                    t: 'Ságy a Process Managery',         d: 'Long-running procesy, kompenzace, eventually consistent',   time: 24, lvl: 4, tag: 'Vzory' },
    { n: '08', route: 'performance_aspects',      t: 'Výkonnostní aspekty',             d: 'Snapshoty, projekce, cache, read-model optimalizace',        time: 20, lvl: 4, tag: 'Vzory' },
    { n: '09', route: 'practical_examples',       t: 'Praktické příklady',              d: 'E-shop, fakturace, inventory — minimal end-to-end',          time: 32, lvl: 3, tag: 'Praxe' },
    { n: '10', route: 'testing_ddd',              t: 'Testování DDD',                   d: 'Unit · Integration · BDD · contract testy agregátů',         time: 18, lvl: 3, tag: 'Praxe' },
    { n: '11', route: 'migration_from_crud',      t: 'Migrace z CRUD',                  d: 'Strangler Fig Pattern — postupný přechod bez stopu',         time: 22, lvl: 3, tag: 'Praxe' },
    { n: '12', route: 'ddd_pain_points',          t: 'DDD v praxi — kde to bolí',       d: '20 reálných problémů: Doctrine, ACL, strangler fig…',        time: 30, lvl: 4, tag: 'Praxe' },
    { n: '13', route: 'anti_patterns',            t: 'Anti-vzory a typické chyby',      d: 'Anemic model, smart UI, leaky abstractions',                 time: 16, lvl: 2, tag: 'Praxe' },
    { n: '14', route: 'when_not_to_use_ddd',      t: 'Kdy DDD nepoužívat',              d: '7 situací, kdy DDD přinese víc škody než užitku',            time: 12, lvl: 2, tag: 'Praxe' },
    { n: '15', route: 'case_study',               t: 'Případová studie',                d: 'E-shop v DDD architektuře, krok za krokem',                  time: 45, lvl: 4, tag: 'Praxe' },
    { n: '16', route: 'ddd_ai',                   t: 'DDD a umělá inteligence',         d: 'Eric Evans · Fowler · Beck · DHH o vztahu DDD a AI',         time: 10, lvl: 1, tag: 'Reference' }
] %}

{% set extras = [
    { route: 'glossary', t: 'Glosář',  d: 'Definice klíčových DDD termínů', tag: 'Reference' },
    { route: 'resources', t: 'Zdroje', d: 'Knihy, blogy, videa, kurzy, repos', tag: 'Reference' }
] %}

{% set total_time = 0 %}
{% for c in chapters %}{% set total_time = total_time + c.time %}{% endfor %}
{% set hours = (total_time / 60)|round(0, 'floor') %}
{% set minutes = total_time - hours * 60 %}

{% block body %}
<div class="land">
    <section class="land-hero">
        <div class="land-left">
            <div class="land-eyebrow">
                <span class="land-eyebrow-num">VOL. I</span>
                <span class="land-eyebrow-rule"></span>
                <span class="land-eyebrow-meta">{{ "now"|date("Y") }} EDITION · ČESKY · ZDARMA</span>
            </div>

            <h1 class="land-title">
                Doménově řízený návrh,<br>
                <span class="land-em">přeložený do Symfony.</span>
            </h1>

            <p class="land-deck">
                Šestnáctikapitolová příručka pro seniorní vývojáře a architekty.
                Od ohraničených kontextů přes <em>CQRS</em> a <em>Event Sourcing</em>
                až po reálné případové studie — v PHP 8.4+ a Symfony 8.
            </p>

            <div class="land-author">
                <div class="land-author-mark" aria-hidden="true"></div>
                <div>
                    <div class="land-author-name">Michal Katuščák</div>
                    <div class="land-author-role">PHP / Symfony · 13+ let komerčního vývoje</div>
                </div>
            </div>

            <div class="land-cta">
                <a class="btn btn-primary" href="{{ path('what_is_ddd') }}">
                    Otevřít první kapitolu <span class="btn-arrow">→</span>
                </a>
                <a class="land-skip" href="{{ path('cqrs') }}">
                    nebo skočit rovnou na <span class="land-skip-tar">CQRS · 05</span>
                </a>
            </div>

            <div class="land-paths">
                <div class="land-path-label">Doporučené čtení</div>
                <div class="land-path-list">
                    <a class="land-path" href="{{ path('what_is_ddd') }}">
                        <span class="land-path-tag">Začátečník</span>
                        <span class="land-path-route">01 → 02 → 04 → 09</span>
                        <span class="land-path-time">≈ 92 min</span>
                    </a>
                    <a class="land-path" href="{{ path('cqrs') }}">
                        <span class="land-path-tag">Pokročilý</span>
                        <span class="land-path-route">05 → 06 → 07 → 10</span>
                        <span class="land-path-time">≈ 90 min</span>
                    </a>
                    <a class="land-path" href="{{ path('when_not_to_use_ddd') }}">
                        <span class="land-path-tag">Architekt</span>
                        <span class="land-path-route">14 → 11 → 12 → 08</span>
                        <span class="land-path-time">≈ 84 min</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="land-right">
            <header class="land-toc-head">
                <span class="land-toc-num">CONTENTS</span>
                <span class="land-toc-rule"></span>
                <span class="land-toc-meta">{{ chapters|length }} kapitol · ~{{ hours }} h {{ minutes }} min čtení</span>
            </header>
            <ol class="land-toc">
                {% for c in chapters %}
                <li>
                    <a class="land-toc-item" href="{{ path(c.route) }}">
                        <span class="land-toc-n">{{ c.n }}</span>
                        <div class="land-toc-text">
                            <span class="land-toc-title">{{ c.t }}</span>
                            <span class="land-toc-desc">{{ c.d }}</span>
                        </div>
                        <div class="land-toc-side">
                            <span class="land-toc-tag">{{ c.tag }}</span>
                            <span class="land-toc-time">{{ c.time }}′</span>
                            <span class="land-toc-bar">
                                {% for i in 1..4 %}<i class="{{ i <= c.lvl ? 'on' : '' }}"></i>{% endfor %}
                            </span>
                        </div>
                    </a>
                </li>
                {% endfor %}
                {% for e in extras %}
                <li>
                    <a class="land-toc-item" href="{{ path(e.route) }}">
                        <span class="land-toc-n">—</span>
                        <div class="land-toc-text">
                            <span class="land-toc-title">{{ e.t }}</span>
                            <span class="land-toc-desc">{{ e.d }}</span>
                        </div>
                        <div class="land-toc-side">
                            <span class="land-toc-tag">{{ e.tag }}</span>
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ol>
        </div>
    </section>

    <section class="land-featured">
        <a class="land-featured-card" href="{{ path('case_study') }}" aria-label="Otevřít případovou studii">
            <div>
                <div class="land-featured-eyebrow">FEATURED · KAPITOLA 15</div>
                <h2 class="land-featured-title">Případová studie: e-shop end-to-end</h2>
                <p class="land-featured-deck">
                    Kompletní e-shop v DDD architektuře krok za krokem — od ohraničených kontextů
                    a agregátů přes CQRS čtení/zápisu po projekce a event-driven workflow.
                    Syntéza všeho, co předchozí kapitoly probírají odděleně.
                </p>
            </div>
            <span class="btn btn-ghost" aria-hidden="true">Otevřít <span class="btn-arrow">→</span></span>
        </a>
    </section>

    <div class="land-marq">
        <div class="land-marq-row">
            <span>PHP 8.4+</span><span class="land-marq-dot">·</span>
            <span>Symfony 8</span><span class="land-marq-dot">·</span>
            <span>Doctrine ORM</span><span class="land-marq-dot">·</span>
            <span>Messenger</span><span class="land-marq-dot">·</span>
            <span>EventStore</span><span class="land-marq-dot">·</span>
            <span>{{ chapters|length }} kapitol</span><span class="land-marq-dot">·</span>
            <span>česky</span><span class="land-marq-dot">·</span>
            <span>zdarma</span><span class="land-marq-dot">·</span>
            <span>open source</span>
        </div>
    </div>
</div>
{% endblock %}
