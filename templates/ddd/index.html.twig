{% extends 'base.html.twig' %}

{% block title %}Domain-Driven Design v Symfony 8 – průvodce architekturou{% endblock %}
{% block meta_description %}Pětadvacetidílná příručka pro seniorní vývojáře. Od subdomén a Bounded Contextu přes návrh agregátů, CQRS a Event Sourcing po případovou studii – v PHP 8.4+ a Symfony 8.{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Book",
    "@id": "{{ app.request.schemeAndHttpHost }}/",
    "name": "Domain-Driven Design v Symfony 8",
    "alternateName": "Architektura DDD v Symfony 8",
    "url": "{{ app.request.schemeAndHttpHost }}/",
    "description": "{{ block('meta_description')|escape('js') }}",
    "inLanguage": "cs-CZ",
    "numberOfPages": {{ chapters|length }},
    "bookFormat": "https://schema.org/EBook",
    "isAccessibleForFree": true,
    "image": "{{ app.request.schemeAndHttpHost }}{{ asset('images/social.png') }}",
    "author": {
        "@type": "Person",
        "name": "Michal Katuščák",
        "url": "https://www.katuscak.cz/"
    },
    "publisher": {
        "@type": "Person",
        "name": "Michal Katuščák",
        "url": "https://www.katuscak.cz/"
    },
    "hasPart": [
        {%- for c in chapters -%}
        {
            "@type": "Chapter",
            "position": {{ loop.index }},
            "name": "{{ c.t|escape('js') }}",
            "url": "{{ app.request.schemeAndHttpHost }}{{ path(c.route) }}",
            "description": "{{ c.d|escape('js') }}"
        }{% if not loop.last %},{% endif %}
        {%- endfor -%}
    ]
}
</script>
{% endblock %}

{% set total_time = 0 %}
{% for c in chapters %}{% set total_time = total_time + c.time %}{% endfor %}
{% set hours = (total_time / 60)|round(0, 'floor') %}
{% set minutes = total_time - hours * 60 %}

{% block body %}
<div class="land">
    <section class="land-hero">
        <div class="land-left">
            <div class="land-eyebrow">
                <span class="land-eyebrow-num">PŘÍRUČKA</span>
                <span class="land-eyebrow-rule"></span>
                <span class="land-eyebrow-meta">ČESKY · ZDARMA · OPEN SOURCE</span>
            </div>

            <h1 class="land-title">
                Domain-Driven Design<br>
                <span class="land-em">v Symfony 8.</span>
            </h1>

            <p class="land-deck">
                Pětadvacetidílná příručka pro seniorní vývojáře a architekty.
                Od subdomén a ohraničených kontextů přes návrh agregátů,
                <em>CQRS</em> a <em>Event Sourcing</em> až po případovou studii –
                v PHP 8.4+ a Symfony 8.
            </p>

            <a class="land-author" href="{{ path('about') }}">
                <img
                    class="land-author-mark"
                    src="{{ asset('img/author.webp') }}"
                    alt="Michal Katuščák – autor průvodce"
                    width="40"
                    height="40"
                    loading="eager"
                >
                <div>
                    <div class="land-author-name">Michal Katuščák</div>
                    <div class="land-author-role">PHP / Symfony · 13+ let komerčního vývoje</div>
                </div>
            </a>

            <div class="land-cta">
                <a class="btn btn-primary" href="{{ path('what_is_ddd') }}">
                    Otevřít první kapitolu <span class="btn-arrow">→</span>
                </a>
                <a class="land-skip" href="{{ path('cqrs') }}">
                    nebo skočit rovnou na <span class="land-skip-tar">CQRS · 13</span>
                </a>
            </div>

            <div class="land-paths">
                <div class="land-path-label">Doporučené čtení</div>
                <div class="land-path-list">
                    <a class="land-path" href="{{ path('what_is_ddd') }}">
                        <span class="land-path-tag">Začátečník</span>
                        <span class="land-path-route">01 → 06 → 10 → 11</span>
                        <span class="land-path-time">≈ 77 min</span>
                    </a>
                    <a class="land-path" href="{{ path('aggregate_design') }}">
                        <span class="land-path-tag">Pokročilý</span>
                        <span class="land-path-route">07 → 13 → 14 → 16</span>
                        <span class="land-path-time">≈ 138 min</span>
                    </a>
                    <a class="land-path" href="{{ path('subdomains') }}">
                        <span class="land-path-tag">Architekt</span>
                        <span class="land-path-route">02 → 03 → 20 → 05</span>
                        <span class="land-path-time">≈ 98 min</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="land-right">
            <header class="land-toc-head">
                <span class="land-toc-num">OBSAH</span>
                <span class="land-toc-rule"></span>
                <span class="land-toc-meta">{{ chapters|length }} kapitol · ~{{ hours }} h {{ minutes }} min čtení</span>
            </header>
            <ol class="land-toc">
                {% for c in chapters %}
                <li>
                    <a class="land-toc-item" href="{{ path(c.route) }}">
                        <span class="land-toc-n">{{ c.n }}</span>
                        <div class="land-toc-text">
                            <span class="land-toc-title">{{ c.t }}</span>
                            <span class="land-toc-desc">{{ c.d }}</span>
                        </div>
                        <div class="land-toc-side">
                            <span class="land-toc-tag">{{ c.tag }}</span>
                            <span class="land-toc-time">{{ c.time }}′</span>
                            <span class="land-toc-bar">
                                {% for i in 1..4 %}<i class="{{ i <= c.lvl ? 'on' : '' }}"></i>{% endfor %}
                            </span>
                        </div>
                    </a>
                </li>
                {% endfor %}
                {% for e in extras %}
                <li>
                    <a class="land-toc-item" href="{{ path(e.route) }}">
                        <span class="land-toc-n">–</span>
                        <div class="land-toc-text">
                            <span class="land-toc-title">{{ e.t }}</span>
                            <span class="land-toc-desc">{{ e.d }}</span>
                        </div>
                        <div class="land-toc-side">
                            <span class="land-toc-tag">{{ e.tag }}</span>
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ol>
        </div>
    </section>

    <section class="land-featured">
        <a class="land-featured-card" href="{{ path('case_study') }}" aria-label="Otevřít případovou studii: systém pro správu projektů end-to-end">
            <div>
                <div class="land-featured-eyebrow">DOPORUČUJEME · KAPITOLA 25</div>
                <h2 class="land-featured-title">Případová studie: systém pro správu projektů end-to-end</h2>
                <p class="land-featured-deck">
                    Kompletní systém pro správu projektů a úkolů v DDD architektuře krok za krokem –
                    od doménové analýzy a ohraničených kontextů přes agregáty a CQRS po projekce
                    s reconciliation a event-driven workflow. Syntéza všeho, co předchozí kapitoly
                    probírají odděleně.
                </p>
            </div>
            <span class="btn btn-ghost" aria-hidden="true">Otevřít <span class="btn-arrow">→</span></span>
        </a>
    </section>

    <div class="land-marq" aria-hidden="true">
        <div class="land-marq-row">
            <span>PHP 8.4+</span><span class="land-marq-dot">·</span>
            <span>Symfony 8</span><span class="land-marq-dot">·</span>
            <span>Doctrine ORM</span><span class="land-marq-dot">·</span>
            <span>Messenger</span><span class="land-marq-dot">·</span>
            <span>EventStore</span><span class="land-marq-dot">·</span>
            <span>{{ chapters|length }} kapitol</span><span class="land-marq-dot">·</span>
            <span>česky</span><span class="land-marq-dot">·</span>
            <span>zdarma</span><span class="land-marq-dot">·</span>
            <span>open source</span>
        </div>
    </div>
</div>
{% endblock %}
