            } %}
            {% endset %}
            {% include '_partials/callout.html.twig' with {
                type: 'anti',
                body: _callout_body
            } %}

            {% set _callout_body %}

                <h3 id="anemicky-spravny-heading">Správně: Entita User s bohatou doménovou logikou</h3>
                <p>
                    Správný přístup přesouvá doménovou logiku přímo do entity. Entita sama zajišťuje své invarianty
                    a vystavuje doménově orientované metody místo holých setterů.
                </p>
            {% endset %}
            {% include '_partials/callout.html.twig' with {
                type: 'note',
                body: _callout_body
            } %}

            {% set _callout_body %}

                <h3>Příklad: Bohatá entita User (správně)</h3>
                {% set _code %}␀PLACEHOLDER1␀{% endset %}
            {% include '_partials/code_block.html.twig' with {
                filename: 'src/UserManagement/Domain/ValueObject/UserStatus.php',
                language: 'php',
                code: _code,
                highlights: []
