            } %}

            {% set _callout_body %}

                <h3 id="ubiq-spravne-heading">Správně: Konzistentní jazyk napříč všemi vrstvami</h3>
                <p>
                    Ubiquitous Language vyžaduje investici: vývojáři musí naslouchat doménovým expertům,
                    porozumět jejich terminologii a tu pak konzistentně přenést do kódu. Výsledkem je kód,
                    který doménový expert může číst a rozumět mu.
                </p>
            {% endset %}
            {% include '_partials/callout.html.twig' with {
                type: 'note',
                body: _callout_body
            } %}

            {% set _callout_body %}

                <h3>Příklad: Konzistentní Ubiquitous Language (správně)</h3>
                {% set _code %}␀PLACEHOLDER15␀{% endset %}
            {% include '_partials/code_block.html.twig' with {
