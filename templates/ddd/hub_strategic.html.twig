{% extends 'base.html.twig' %}

{% block title %}Strategický DDD – rozcestník | DDD Symfony 8{% endblock %}
{% block meta_description %}Strategická vrstva Domain-Driven Design: identifikace subdomén (Core, Supporting, Generic) a context mapping (8 vztahů mezi Bounded Contexts). Než začnete kódit, rozhodněte správně.{% endblock %}
{% block breadcrumb_name %}Strategie{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "url": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "name": "Strategický DDD – rozcestník",
    "description": "{{ block('meta_description')|escape('js') }}",
    "inLanguage": "cs-CZ",
    "isPartOf": {
        "@type": "WebSite",
        "name": "Architektura DDD v Symfony 8",
        "url": "{{ app.request.schemeAndHttpHost }}"
    }
}
</script>
{% endblock %}

{% set total_time = 0 %}{% for c in hub_chapters %}{% set total_time = total_time + c.time %}{% endfor %}
{% set updated = "now"|date("j. n. Y") %}

{% block body %}
    {% include '_partials/hub.html.twig' with {
        hub_eyebrow: 'PŘÍRUČKA · ROZCESTNÍK · STRATEGIE',
        hub_h_main: 'Strategický DDD,',
        hub_h_em: 'než nakreslíte první třídu.',
        hub_deck: 'Tato sekce řeší <strong>kde</strong> a <strong>proč</strong> — identifikaci jádra domény a vztahy mezi bounded contexty. Bez ní jsou Entity, VO a Agregáty náhodný shluk objektů bez kontextu. Výstupem je rozhodnutí, kam investovat modelovací úsilí a jak nakreslit Context Map.',
        hub_meta: [
            { k: 'Kapitol', v: hub_chapters|length },
            { k: 'Čtení', v: '~' ~ total_time ~ ' min' },
            { k: 'Předpoklady', v: 'Základy DDD' },
            { k: 'Aktualizace', v: updated }
        ],
        hub_part: 'PART I.5',
        hub_part_title: 'Subdomény · vztahy · context mapping',
        hub_part_sub: 'co řešit dřív než kód',
        hub_chapters: hub_chapters
    } only %}
{% endblock %}
