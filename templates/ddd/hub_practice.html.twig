{% extends 'base.html.twig' %}

{% block title %}Praxe a provoz DDD – rozcestník | DDD Symfony 8{% endblock %}
{% block meta_description %}Šest kapitol o tom, co se reálně děje, když DDD potká legacy kód, deadline a tým: testování, migrace z CRUD, microservices, pain points, anti-vzory, kdy DDD nepoužívat.{% endblock %}
{% block breadcrumb_name %}Praxe{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "url": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "name": "Praxe a provoz DDD – rozcestník",
    "description": "{{ block('meta_description')|escape('js') }}",
    "inLanguage": "cs-CZ",
    "isPartOf": {
        "@type": "WebSite",
        "name": "Architektura DDD v Symfony 8",
        "url": "{{ app.request.schemeAndHttpHost }}"
    }
}
</script>
{% endblock %}

{% set total_time = 0 %}{% for c in hub_chapters %}{% set total_time = total_time + c.time %}{% endfor %}
{% set updated = "now"|date("j. n. Y") %}

{% block body %}
    {% include '_partials/hub.html.twig' with {
        hub_eyebrow: 'PŘÍRUČKA · ROZCESTNÍK · PRAXE A PROVOZ',
        hub_h_main: 'Praxe a provoz,',
        hub_h_em: 'kde to bolí a kde se to láme.',
        hub_deck: 'Sekce o překladu teorie do reality. <strong>Testování</strong> ukazuje, jak vypadá zdravý běh. <strong>Migrace z CRUD</strong> popisuje strangler fig přechod ke zdravému modelu. <strong>Microservices a Bounded Contexts</strong> řeší, kdy z BC udělat servisu a kdy zůstat u modulárního monolitu. <strong>Pain points</strong>, <strong>anti-vzory</strong> a <strong>kdy DDD nepoužívat</strong> jsou poznámky, které obvykle slyšíte až při code review – zde jsou pohromadě.',
        hub_meta: [
            { k: 'Kapitol', v: hub_chapters|length },
            { k: 'Čtení', v: '~' ~ total_time ~ ' min' },
            { k: 'Předpoklady', v: 'Taktika · architektura · vzory' },
            { k: 'Aktualizace', v: updated }
        ],
        hub_part: 'PART V',
        hub_part_title: 'Testy · migrace · služby · pasti',
        hub_part_sub: 'realita za diagramy',
        hub_chapters: hub_chapters
    } only %}
{% endblock %}
