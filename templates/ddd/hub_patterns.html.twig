{% extends 'base.html.twig' %}

{% block title %}Pokročilé vzory DDD – rozcestník | DDD Symfony 8{% endblock %}
{% block meta_description %}Pět kapitol o pokročilých vzorech a infrastruktuře: CQRS, Event Sourcing, ságy, Outbox Pattern a optimalizace read modelů a projekcí v Symfony 8.{% endblock %}
{% block breadcrumb_name %}Vzory{% endblock %}

{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "url": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}",
    "name": "Pokročilé vzory DDD – rozcestník",
    "description": "{{ block('meta_description')|escape('js') }}",
    "inLanguage": "cs-CZ",
    "isPartOf": {
        "@type": "WebSite",
        "name": "Architektura DDD v Symfony 8",
        "url": "{{ app.request.schemeAndHttpHost }}"
    }
}
</script>
{% endblock %}

{% set total_time = 0 %}{% for c in hub_chapters %}{% set total_time = total_time + c.time %}{% endfor %}
{% set updated = "now"|date("j. n. Y") %}

{% block body %}
    {% include '_partials/hub.html.twig' with {
        hub_eyebrow: 'PŘÍRUČKA · ROZCESTNÍK · POKROČILÉ VZORY',
        hub_h_main: 'Pokročilé vzory,',
        hub_h_em: 'kde se DDD potkává s frameworkem.',
        hub_deck: 'Vrstva, ve které model ovlivňuje infrastrukturu. <strong>CQRS</strong> dělí čtení a zápis přes Messenger. <strong>Event Sourcing</strong> ukládá stav jako sekvenci doménových událostí. <strong>Ságy</strong> řídí dlouhotrvající procesy s kompenzacemi. <strong>Outbox Pattern</strong> spolehlivě publikuje eventy bez dual-write rizika. A <strong>read modely a projekce</strong> rozhodují, zda architektura v provozu obstojí.',
        hub_meta: [
            { k: 'Kapitol', v: hub_chapters|length },
            { k: 'Čtení', v: '~' ~ total_time ~ ' min' },
            { k: 'Stack', v: 'Symfony Messenger · Doctrine ORM 3' },
            { k: 'Aktualizace', v: updated }
        ],
        hub_part: 'PART IV',
        hub_part_title: 'CQRS · ES · Sagy · Outbox · projekce',
        hub_part_sub: 'pokročilé vzory v Symfony 8',
        hub_chapters: hub_chapters
    } only %}
{% endblock %}
