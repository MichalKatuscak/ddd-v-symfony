        published: '2026-04-29',
        last_updated: '2026-04-29',
        author: 'M. Katuščák'
    } %}
    <div class="art-body">
        <p>Obsah se právě dokončuje. Mezitím doporučujeme <a href="{{ path('hub_reference') }}">Reference rozcestník</a>.</p>
