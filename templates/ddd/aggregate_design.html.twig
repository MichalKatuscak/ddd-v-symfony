    /** @var Collection<int, OrderItem> */
    #[ORM\OneToMany(
        mappedBy: 'order',
        targetEntity: OrderItem::class,
        cascade: ['persist', 'remove'], // OK: kaskáda uvnitř agregátu
        orphanRemoval: true,
    )]
