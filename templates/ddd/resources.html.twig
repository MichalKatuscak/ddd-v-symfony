{% extends 'base.html.twig' %}

{% block title %}Zdroje a další četba o Domain-Driven Design | DDD Symfony{% endblock %}

{% block meta_description %}Vybrané knihy, články, videa, repozitáře a kurzy o Domain-Driven Design a CQRS v Symfony. Doporučená četba od Evanse, Vernona a dalších autorů.{% endblock %}

{% block meta_keywords %}DDD zdroje, knihy o DDD, články o DDD, videa o DDD, konference, komunita, Eric Evans, Vaughn Vernon, Symfony zdroje, PHP zdroje{% endblock %}

{% block og_type %}article{% endblock %}

{% block article_published_time %}2025-04-24{% endblock %}
{% block article_modified_time %}2026-04-12{% endblock %}

{% block breadcrumb_name %}Zdroje a další četba{% endblock %}

{% block structured_data %}
    <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "TechArticle",
          "headline": "Zdroje a další četba o Domain-Driven Design",
          "description": "{{ block('meta_description')|escape('js') }}",
          "keywords": "{{ block('meta_keywords')|escape('js') }}",
          "author": {
            "@type": "Person",
            "name": "Michal Katuščák",
            "url": "https://www.katuscak.cz/",
            "sameAs": [
                "https://blog.katuscak.cz/",
                "https://www.linkedin.com/in/michal-katu%C5%A1%C4%8D%C3%A1k-04a249184/"
            ]
          },
          "publisher": {
            "@type": "Person",
            "name": "Michal Katuščák"
          },
          "datePublished": "2025-04-24",
          "dateModified": "{{ block('article_modified_time')|trim }}",
          "image": "{{ app.request.schemeAndHttpHost }}{{ asset('images/social.png') }}",
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": "{{ app.request.schemeAndHttpHost }}{{ app.request.pathInfo }}"
          }
        }
    </script>
{% endblock %}

{% block body %}
<article class="article">
    {% include '_partials/article_head.html.twig' with {
        category: 'Reference',
        title: 'Zdroje a další četba',
        deck: 'Vybraná literatura, články, videa, repozitáře a kurzy o Domain-Driven Design a CQRS – primární i sekundární zdroje, na které se průvodce odkazuje.',
        published: block('article_published_time'),
        last_updated: block('article_modified_time'),
        author: 'M. Katuščák'
    } %}

    {% include '_partials/article_toc.html.twig' %}

    <div class="art-body">
        <p>
            Seznam je <strong>kurátorský, ne vyčerpávající</strong>. Zařazené zdroje mají buď
            referenční hodnotu (Evans, Vernon, Fowler), nebo přidávají něco, co jinde nenajdete.
            U každé položky je krátká nota o důvodu zařazení.
        </p>

        <section id="books" aria-labelledby="books-heading">
            <h2 id="books-heading" class="h-section"><span class="h-num">A</span> Knihy</h2>
            <ol class="res-list">
                <li class="res-item">
                    <a class="res-link" href="https://www.domainlanguage.com/ddd/reference/" target="_blank" rel="noopener">
                        <span class="res-num">01</span>
                        <div class="res-body">
                            <div class="res-meta">Eric Evans · 2003 · Addison-Wesley</div>
                            <div class="res-title">Domain-Driven Design: Tackling Complexity in the Heart of Software</div>
                            <p class="res-desc">Zakladatelská kniha. Definuje pojmy <em>Ubiquitous Language</em>, <em>Bounded Context</em>, <em>Aggregate</em> a celý slovník strategického i taktického designu. Stále nejdůležitější primární zdroj.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://www.amazon.com/Implementing-Domain-Driven-Design-Vaughn-Vernon/dp/0321834577" target="_blank" rel="noopener">
                        <span class="res-num">02</span>
                        <div class="res-body">
                            <div class="res-meta">Vaughn Vernon · 2013 · Addison-Wesley</div>
                            <div class="res-title">Implementing Domain-Driven Design</div>
                            <p class="res-desc">Praktický druhý díl k Evansovi. Konkrétní implementační vzory, příklady aggregátů, integrace mezi kontexty a propojení s CQRS i Event Sourcingem.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://www.amazon.com/Domain-Driven-Design-Distilled-Vaughn-Vernon/dp/0134434420" target="_blank" rel="noopener">
                        <span class="res-num">03</span>
                        <div class="res-body">
                            <div class="res-meta">Vaughn Vernon · 2016 · Addison-Wesley</div>
                            <div class="res-title">Domain-Driven Design Distilled</div>
                            <p class="res-desc">Stručná destilace klíčových konceptů. Vhodný úvod, pokud váháte, jestli investovat čas do plné Implementing DDD.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://cqrs.files.wordpress.com/2010/11/cqrs_documents.pdf" target="_blank" rel="noopener">
                        <span class="res-num">04</span>
                        <div class="res-body">
                            <div class="res-meta">Greg Young · 2010 · PDF (zdarma)</div>
                            <div class="res-title">CQRS Documents</div>
                            <p class="res-desc">Sbírka původních textů od autora pojmu CQRS. Stručné a hutné – definuje, co CQRS je a co není, vč. vztahu k Event Sourcingu.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://www.oreilly.com/library/view/learning-domain-driven-design/9781098100124/" target="_blank" rel="noopener">
                        <span class="res-num">05</span>
                        <div class="res-body">
                            <div class="res-meta">Vlad Khononov · 2021 · O'Reilly</div>
                            <div class="res-title">Learning Domain-Driven Design</div>
                            <p class="res-desc">Modernější druhý pohled. Klade větší důraz na strategický design a na rozhodování, kde DDD vůbec dává smysl. Dobrý doplněk k Evansovi.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
            </ol>
        </section>

        <section id="articles" aria-labelledby="articles-heading">
            <h2 id="articles-heading" class="h-section"><span class="h-num">B</span> Články</h2>
            <ol class="res-list">
                <li class="res-item">
                    <a class="res-link" href="https://martinfowler.com/bliki/CQRS.html" target="_blank" rel="noopener">
                        <span class="res-num">01</span>
                        <div class="res-body">
                            <div class="res-meta">Martin Fowler · martinfowler.com</div>
                            <div class="res-title">CQRS</div>
                            <p class="res-desc">Krátké a přesné vymezení vzoru. Mimo jiné jasně říká, kdy se <em>nehodí</em>.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://martinfowler.com/bliki/BoundedContext.html" target="_blank" rel="noopener">
                        <span class="res-num">02</span>
                        <div class="res-body">
                            <div class="res-meta">Martin Fowler · martinfowler.com</div>
                            <div class="res-title">Bounded Context</div>
                            <p class="res-desc">Definice pojmu z pera autora, který ho zpopularizoval mimo DDD komunitu. Užitečná čítanka při vysvětlování konceptu netechnickému publiku.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://www.jimmybogard.com/vertical-slice-architecture/" target="_blank" rel="noopener">
                        <span class="res-num">03</span>
                        <div class="res-body">
                            <div class="res-meta">Jimmy Bogard · jimmybogard.com</div>
                            <div class="res-title">Vertical Slice Architecture</div>
                            <p class="res-desc">Argument pro vertikální slicing místo horizontálních vrstev. Důležité, pokud uvažujete o organizaci kódu uvnitř Bounded Contextu.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://herbertograca.com/2017/11/16/explicit-architecture-01-ddd-hexagonal-onion-clean-cqrs-how-i-put-it-all-together/" target="_blank" rel="noopener">
                        <span class="res-num">04</span>
                        <div class="res-body">
                            <div class="res-meta">Herberto Graca · herbertograca.com</div>
                            <div class="res-title">Explicit Architecture: DDD, Hexagonal, Onion, Clean, CQRS</div>
                            <p class="res-desc">Pokus o syntézu několika architektonických škol do jedné konzistentní mapy. Užitečné pro zorientování se v terminologickém zmatku.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
                <li class="res-item">
                    <a class="res-link" href="https://medium.com/@skowron.dev/elevate-your-symfony-projects-implementing-ddd-cqrs-and-hexagonal-architecture-606c81cfd287" target="_blank" rel="noopener">
                        <span class="res-num">05</span>
                        <div class="res-body">
                            <div class="res-meta">Jakub Skowron · Medium</div>
                            <div class="res-title">Implementing DDD, CQRS and Hexagonal Architecture in Symfony</div>
                            <p class="res-desc">Konkrétní průchod skládáním DDD, CQRS a hexagonální architektury v Symfony – dobré srovnání proti řešením v této příručce.</p>
                        </div>
                        <span class="res-arrow" aria-hidden="true">↗</span>
                    </a>
                </li>
            </ol>
        </section>

        <section id="videos" aria-labelledby="videos-heading">
