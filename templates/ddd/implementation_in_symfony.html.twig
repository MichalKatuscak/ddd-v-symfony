        public readonly string $name,
        public readonly string $email,
        public readonly string $password
    ) {
    }
}{% endverbatim %}{% endset %}
            {% include '_partials/code_block.html.twig' with {
                filename: 'src/UserManagement/Registration/Command/RegisterUser.php',
