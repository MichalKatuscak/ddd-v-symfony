                filename: 'src/Warehouse/Application/Handler/ReserveStockOnPaymentSucceeded.php',
                language: 'php',
                code: _code,
                highlights: []
            } %}

        <p><strong>Handler 3 – CreateShipmentOnStockReserved:</strong></p>
        {% set _code %}␀PLACEHOLDER4␀{% endset %}
            {% include '_partials/code_block.html.twig' with {
                filename: 'src/Shipping/Application/Handler/CreateShipmentOnStockReserved.php',
                language: 'php',
                code: _code,
                highlights: []
            } %}
    {% endset %}
            {% include '_partials/callout.html.twig' with {
