{# args: chapter_number, category, title, deck, reading_time (min), difficulty (1-4), last_updated, author #}
<header class="art-head">
    <div class="art-crumb">
        {% if chapter_number is defined and chapter_number %}<span>Kapitola {{ chapter_number }}</span>{% endif %}
        {% if chapter_number is defined and chapter_number and category is defined and category %}<span class="crumb-sep">·</span>{% endif %}
        {% if category is defined and category %}<span>{{ category }}</span>{% endif %}
        {% if (chapter_number is defined and chapter_number) or (category is defined and category) %}<span class="crumb-sep">·</span>{% endif %}
        <span class="art-crumb-current">{{ title }}</span>
    </div>

    <h1 class="art-title">{{ title }}</h1>

    {% if deck is defined and deck %}
        <p class="art-deck">{{ deck|raw }}</p>
    {% endif %}

    {% if reading_time is defined or difficulty is defined or last_updated is defined %}
    <div class="art-meta">
        <div class="art-meta-row">
            <span class="art-meta-k">Autor</span>
            <span class="art-meta-v">{{ author|default('M. Katuščák') }}</span>
        </div>
        {% if reading_time is defined and reading_time %}
        <div class="art-meta-row">
            <span class="art-meta-k">Doba čtení</span>
            <span class="art-meta-v">≈ {{ reading_time }} min</span>
        </div>
        {% endif %}
        {% if difficulty is defined and difficulty %}
        <div class="art-meta-row">
            <span class="art-meta-k">Náročnost</span>
            <span class="art-meta-v">
                <span class="diff-bar">
                    {% for i in 1..4 %}<i class="{{ i <= difficulty ? 'on' : '' }}"></i>{% endfor %}
                </span>
                {% set diff_label = ['základní', 'mírně pokročilá', 'pokročilá', 'náročná'] %}
                {{ diff_label[difficulty - 1] }}
            </span>
        </div>
        {% endif %}
        {% if last_updated is defined and last_updated %}
        <div class="art-meta-row">
            <span class="art-meta-k">Aktualizace</span>
            <span class="art-meta-v">{{ last_updated|date("j. n. Y") }}</span>
        </div>
        {% endif %}
    </div>
    {% endif %}
</header>
