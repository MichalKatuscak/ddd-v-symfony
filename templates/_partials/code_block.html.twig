{#
  args:
    filename     – např. 'src/Order/Domain/Order.php'
    language     – 'php' | 'yaml' | 'twig' | 'bash' | 'json' | 'sql' | ...
    code         – surový kód jako string (bude escapovaný); předává se přez include with code: ... nebo přez set + capture
    highlights   – pole čísel řádků (1-based) pro zvýraznění; volitelné

  Použití:
    {% set _code %}<?php
    namespace App;
    final class Order {}
    {% endset %}
    {% include '_partials/code_block.html.twig' with {
        filename: 'src/Order/Domain/Order.php',
        language: 'php',
        code: _code,
        highlights: [3]
    } %}
#}
{%- set _hl = (highlights is defined ? highlights|join(',') : '') -%}
<figure class="code">
    <header class="code-head">
        <span class="code-dot" data-lang="{{ language }}">{{ language }}</span>
        <span class="code-file">{{ filename }}</span>
        <span class="code-spacer"></span>
        <button class="code-copy" type="button" data-copy aria-label="Kopírovat kód">
            <svg width="11" height="11" viewBox="0 0 12 12" aria-hidden="true">
                <rect x="2.5" y="2.5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1"/>
                <rect x="4.5" y="4.5" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1"/>
            </svg>
            <span class="code-copy-label" aria-live="polite">Kopírovat</span>
        </button>
    </header>
    {# tabindex="0" činí scrollable code container fokusovatelný klávesnicí (axe a11y). #}
    <pre class="code-body" data-highlight="{{ _hl }}" tabindex="0"><code class="language-{{ language }}">{{- code|trim('\n') -}}</code></pre>
</figure>
