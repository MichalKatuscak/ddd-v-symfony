{% extends 'base.html.twig' %}

{% block title %}Chyba | Architektura DDD v Symfony 8{% endblock %}
{% block meta_description %}Při zpracování požadavku došlo k chybě.{% endblock %}

{% block body %}
    {% set _code = status_code|default('Chyba') %}
    {% set _desc -%}
        {%- if status_code == 403 -%}
            K této stránce nemáte oprávnění.
        {%- elseif status_code == 500 -%}
            Na serveru došlo k interní chybě. Zkuste to prosím za chvíli.
        {%- elseif status_code == 503 -%}
            Služba je dočasně nedostupná. Zkuste to prosím za chvíli.
        {%- else -%}
            Při zpracování požadavku došlo k chybě. Vraťte se na úvod a zkuste to znovu.
        {%- endif -%}
    {% endset %}
    {% include '_partials/error.html.twig' with {
        code: _code,
        eyebrow: 'Chyba',
        title: 'Něco se pokazilo',
        description: _desc
    } only %}
{% endblock %}
